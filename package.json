{
  "name": "MedDev",
  "version": "3.1.3",
  "description": "Clinic management dashboard with Supabase",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npx serve pages",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --ci --coverageReporters=text --coverageReporters=lcov",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
  "node": ">=18.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "serve": "^14.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/plugin-transform-modules-commonjs": "^7.24.0",
    "@jest/globals": "^29.7.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "backend/utils.js",
      "server.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 50,
        "functions": 50,
        "branches": 50,
        "statements": 50
      }
    },
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageDirectory": "coverage",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": []
  }
}
